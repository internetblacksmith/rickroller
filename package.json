{
  "name": "rickroller",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "node ./bin/www",
    "dev": "nodemon ./bin/www",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,json,md}\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:verbose": "jest --verbose"
  },
  "dependencies": {
    "cookie-parser": "1.4.7",
    "debug": "4.4.1",
    "express": "4.21.2",
    "express-rate-limit": "7.6.0",
    "http-errors": "2.0.0",
    "morgan": "1.10.1",
    "open-graph-scraper": "6.10.0",
    "pug": "3.0.3",
    "spider-detector": "2.1.0",
    "winston": "3.18.0",
    "node-cache": "5.1.2"
  },
  "devDependencies": {
    "@eslint/js": "9.31.0",
    "eslint": "9.31.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-node": "11.1.0",
    "jest": "30.0.5",
    "nodemon": "3.1.10",
    "prettier": "3.6.2",
    "supertest": "7.1.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}